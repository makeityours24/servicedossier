generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  OWNER
  ADMIN
  MEDEWERKER
}

enum UserStatus {
  ACTIEF
  UITGESCHAKELD
}

enum SalonStatus {
  ACTIEF
  GEPAUZEERD
}

enum SalonBranchType {
  HAIR
  MASSAGE
  BEAUTY
}

enum CustomerPackageStatus {
  ACTIEF
  VOLLEDIG_GEBRUIKT
  VERLOPEN
  GEANNULEERD
}

enum PackageDisplayType {
  PAKKET
  STEMPELKAART
}

enum AppointmentStatus {
  GEPLAND
  VOLTOOID
  GEANNULEERD
  NIET_GEKOMEN
}

enum TreatmentPhotoType {
  VOOR
  NA
  ALGEMEEN
}

enum CustomerAccountType {
  PARTICULIER
  BEDRIJF
}

enum AssetType {
  CV
  WARMTEPOMP
  AIRCO
  ZONNEPANELEN
  LAADPAAL
  OVERIG
}

enum AssetStatus {
  ACTIEF
  BUITEN_GEBRUIK
  VERVANGEN
}

enum WorkOrderType {
  STORING
  ONDERHOUD
  MONTAGE
  INSPECTIE
  OPNAME
}

enum WorkOrderStatus {
  NIEUW
  INGEPLAND
  ONDERWEG
  IN_UITVOERING
  AFGEROND
  VERVOLG_NODIG
  GEANNULEERD
}

enum WorkOrderPriority {
  LAAG
  NORMAAL
  HOOG
  SPOED
}

enum WorkOrderAssignmentRole {
  HOOFDMONTEUR
  ASSISTENT
}

enum WorkOrderAssignmentStatus {
  INGEPLAND
  ONDERWEG
  IN_UITVOERING
  AFGEROND
  GEANNULEERD
}

enum InstallateurAttachmentType {
  FOTO
  VIDEO
}

model User {
  id           Int         @id @default(autoincrement())
  salonId      Int?
  isPlatformAdmin Boolean @default(false)
  naam         String
  email        String      @unique
  wachtwoord   String
  sessionVersion Int       @default(0)
  moetWachtwoordWijzigen Boolean @default(false)
  rol          UserRole    @default(MEDEWERKER)
  status       UserStatus  @default(ACTIEF)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  salon        Salon?      @relation(fields: [salonId], references: [id], onDelete: Cascade)
  behandelingen Treatment[]
  afspraken    Appointment[]
  appointmentSegments AppointmentSegment[]
  auditLogs    AuditLog[]  @relation("AuditActor")
  packageUsages CustomerPackageUsage[]
  uploadedTreatmentPhotos TreatmentPhoto[]
  passwordResetTokens PasswordResetToken[]
  workOrderAssignments WorkOrderAssignment[]
  serviceReports ServiceReport[]
  installateurAttachments InstallateurAttachment[]

  @@index([salonId, email])
}

model Customer {
  id              Int         @id @default(autoincrement())
  salonId         Int
  naam            String
  adres           String
  telefoonnummer  String
  geboortedatum   DateTime?
  allergieen      String?
  haartype        String?
  haarkleur       String?
  stylistNotities String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  salon           Salon       @relation(fields: [salonId], references: [id], onDelete: Cascade)
  behandelingen   Treatment[]
  afspraken       Appointment[]
  appointmentVisits AppointmentVisit[]
  appointmentSegments AppointmentSegment[]
  customerPackages CustomerPackage[]
  packageUsages   CustomerPackageUsage[]
  treatmentPhotos TreatmentPhoto[]

  @@unique([salonId, telefoonnummer])
  @@index([salonId, naam])
}

model Treatment {
  id            Int       @id @default(autoincrement())
  salonId       Int
  customerId    Int
  userId        Int?
  sourceAppointmentId Int? @unique
  sourceAppointmentSegmentId Int? @unique
  datum         DateTime
  behandeling   String
  recept        String
  behandelaar   String
  notities      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  salon         Salon     @relation(fields: [salonId], references: [id], onDelete: Cascade)
  customer      Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  user          User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  sourceAppointment Appointment? @relation(fields: [sourceAppointmentId], references: [id], onDelete: SetNull)
  sourceAppointmentSegment AppointmentSegment? @relation(fields: [sourceAppointmentSegmentId], references: [id], onDelete: SetNull)
  packageUsages CustomerPackageUsage[]
  photos        TreatmentPhoto[]

  @@index([salonId, datum])
  @@index([customerId, datum])
  @@index([behandelaar, datum])
}

model Appointment {
  id          Int               @id @default(autoincrement())
  salonId     Int
  customerId  Int
  userId      Int?
  datumStart  DateTime
  datumEinde  DateTime
  duurMinuten Int               @default(30)
  behandeling String
  behandelingKleur String       @default("#B42323")
  notities    String?
  status      AppointmentStatus @default(GEPLAND)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  salon       Salon             @relation(fields: [salonId], references: [id], onDelete: Cascade)
  customer    Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  user        User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  convertedTreatment Treatment?

  @@index([salonId, datumStart])
  @@index([customerId, datumStart])
  @@index([userId, datumStart])
  @@index([salonId, status])
}

model AppointmentVisit {
  id          Int               @id @default(autoincrement())
  salonId     Int
  customerId  Int
  datum       DateTime
  notities    String?
  status      AppointmentStatus @default(GEPLAND)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  salon       Salon             @relation(fields: [salonId], references: [id], onDelete: Cascade)
  customer    Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  segments    AppointmentSegment[]

  @@index([salonId, datum])
  @@index([customerId, datum])
  @@index([salonId, status])
}

model AppointmentSegment {
  id               Int               @id @default(autoincrement())
  visitId          Int
  salonId          Int
  customerId       Int
  userId           Int?
  datumStart       DateTime
  datumEinde       DateTime
  duurMinuten      Int               @default(30)
  behandeling      String
  behandelingKleur String            @default("#B42323")
  notities         String?
  status           AppointmentStatus @default(GEPLAND)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  visit            AppointmentVisit  @relation(fields: [visitId], references: [id], onDelete: Cascade)
  salon            Salon             @relation(fields: [salonId], references: [id], onDelete: Cascade)
  customer         Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  user             User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  convertedTreatment Treatment?

  @@index([visitId, datumStart])
  @@index([salonId, datumStart])
  @@index([customerId, datumStart])
  @@index([userId, datumStart])
  @@index([salonId, status])
}

model Salon {
  id            Int            @id @default(autoincrement())
  naam          String
  slug          String         @unique
  status        SalonStatus    @default(ACTIEF)
  email         String?
  telefoonnummer String?
  adres         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  instellingen  SalonSettings?
  users         User[]
  customers     Customer[]
  treatments    Treatment[]
  appointments  Appointment[]
  appointmentVisits AppointmentVisit[]
  appointmentSegments AppointmentSegment[]
  recipeTemplates RecipeTemplate[]
  auditLogs     AuditLog[]
  packageTypes  PackageType[]
  customerPackages CustomerPackage[]
  packageUsages CustomerPackageUsage[]
  treatmentPhotos TreatmentPhoto[]
  customerAccounts CustomerAccount[]
  serviceLocations ServiceLocation[]
  assets       Asset[]
  workOrders   WorkOrder[]
  serviceReports ServiceReport[]
  installateurAttachments InstallateurAttachment[]
}

model SalonSettings {
  id             Int      @id @default(autoincrement())
  salonId        Int      @unique
  weergavenaam   String
  branchType     SalonBranchType @default(HAIR)
  logoUrl        String?
  logoBlobPath   String?
  primaireKleur  String   @default("#b42323")
  contactEmail   String?
  contactTelefoon String?
  adres          String?
  treatmentPresets String[] @default([])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  salon          Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)
}

model RecipeTemplate {
  id           Int      @id @default(autoincrement())
  salonId      Int
  naam         String
  behandeling  String
  recept       String
  notities     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  salon        Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)

  @@index([salonId, naam])
}

model PackageType {
  id                    Int       @id @default(autoincrement())
  salonId               Int
  naam                  String
  omschrijving          String?
  totaalBeurten         Int
  pakketPrijsCents      Int
  lossePrijsCents       Int
  standaardBehandeling  String
  weergaveType          PackageDisplayType @default(PAKKET)
  isActief              Boolean   @default(true)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  salon                 Salon     @relation(fields: [salonId], references: [id], onDelete: Cascade)
  customerPackages      CustomerPackage[]

  @@index([salonId, naam])
}

model CustomerPackage {
  id                         Int                    @id @default(autoincrement())
  salonId                    Int
  customerId                 Int
  packageTypeId              Int
  gekochtOp                  DateTime               @default(now())
  naamSnapshot               String
  standaardBehandelingSnapshot String
  weergaveTypeSnapshot       PackageDisplayType     @default(PAKKET)
  totaalBeurten              Int
  resterendeBeurten          Int
  pakketPrijsCents           Int
  lossePrijsCents            Int
  status                     CustomerPackageStatus  @default(ACTIEF)
  notities                   String?
  createdAt                  DateTime               @default(now())
  updatedAt                  DateTime               @updatedAt
  salon                      Salon                  @relation(fields: [salonId], references: [id], onDelete: Cascade)
  customer                   Customer               @relation(fields: [customerId], references: [id], onDelete: Cascade)
  packageType                PackageType            @relation(fields: [packageTypeId], references: [id], onDelete: Restrict)
  usages                     CustomerPackageUsage[]

  @@index([salonId, customerId])
  @@index([customerId, status])
  @@index([packageTypeId])
}

model CustomerPackageUsage {
  id                Int      @id @default(autoincrement())
  salonId           Int
  customerPackageId Int
  customerId        Int
  treatmentId       Int?
  userId            Int?
  datum             DateTime
  aantalAfgeboekt   Int      @default(1)
  notitie           String?
  createdAt         DateTime @default(now())
  salon             Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)
  customerPackage   CustomerPackage @relation(fields: [customerPackageId], references: [id], onDelete: Cascade)
  customer          Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  treatment         Treatment? @relation(fields: [treatmentId], references: [id], onDelete: SetNull)
  user              User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([salonId, customerId])
  @@index([customerPackageId, datum])
  @@index([treatmentId])
}

model TreatmentPhoto {
  id               Int                @id @default(autoincrement())
  salonId          Int
  customerId       Int
  treatmentId      Int
  uploadedByUserId Int?
  url              String
  blobPath         String
  bestandNaam      String
  mimeType         String
  soort            TreatmentPhotoType @default(ALGEMEEN)
  notitie          String?
  createdAt        DateTime           @default(now())
  salon            Salon              @relation(fields: [salonId], references: [id], onDelete: Cascade)
  customer         Customer           @relation(fields: [customerId], references: [id], onDelete: Cascade)
  treatment        Treatment          @relation(fields: [treatmentId], references: [id], onDelete: Cascade)
  uploadedByUser   User?              @relation(fields: [uploadedByUserId], references: [id], onDelete: SetNull)

  @@index([salonId, customerId, createdAt])
  @@index([treatmentId, createdAt])
  @@index([uploadedByUserId, createdAt])
}

model LoginThrottle {
  id           Int       @id @default(autoincrement())
  key          String    @unique
  email        String?
  ipAddress    String?
  salonSlug    String?
  attemptCount Int       @default(0)
  windowStart  DateTime
  blockedUntil DateTime?
  lastAttemptAt DateTime @default(now())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([email])
  @@index([ipAddress])
  @@index([salonSlug])
  @@index([blockedUntil])
}

model ActionThrottle {
  id            Int       @id @default(autoincrement())
  key           String    @unique
  action        String
  actorUserId   Int?
  salonId       Int?
  ipAddress     String?
  attemptCount  Int       @default(0)
  windowStart   DateTime
  blockedUntil  DateTime?
  lastAttemptAt DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([action, actorUserId])
  @@index([salonId, action])
  @@index([ipAddress])
  @@index([blockedUntil])
}

model PasswordResetToken {
  id            Int      @id @default(autoincrement())
  userId        Int
  tokenHash     String   @unique
  expiresAt     DateTime
  usedAt        DateTime?
  requestedByIp String?
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt])
}

model AuditLog {
  id          Int       @id @default(autoincrement())
  salonId     Int?
  actorUserId Int?
  action      String
  entityType  String
  entityId    String?
  message     String?
  ipAddress   String?
  metadata    Json?
  createdAt   DateTime  @default(now())
  salon       Salon?    @relation(fields: [salonId], references: [id], onDelete: SetNull)
  actorUser   User?     @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([salonId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([entityType, entityId])
  @@index([action, createdAt])
}

model CustomerAccount {
  id          Int                 @id @default(autoincrement())
  salonId     Int
  type        CustomerAccountType @default(PARTICULIER)
  naam        String
  klantnummer String?
  email       String?
  telefoon    String?
  factuurEmail String?
  kvkNummer   String?
  btwNummer   String?
  notities    String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  salon       Salon               @relation(fields: [salonId], references: [id], onDelete: Cascade)
  locations   ServiceLocation[]
  assets      Asset[]
  workOrders  WorkOrder[]
  serviceReports ServiceReport[]
  installateurAttachments InstallateurAttachment[]

  @@index([salonId, naam])
  @@index([salonId, telefoon])
  @@index([salonId, email])
}

model ServiceLocation {
  id                  Int      @id @default(autoincrement())
  salonId             Int
  customerAccountId   Int
  naam                String?
  adresregel1         String
  adresregel2         String?
  postcode            String
  plaats              String
  land                String   @default("NL")
  toegangsinstructies String?
  locatieNotities     String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  salon               Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)
  customerAccount     CustomerAccount @relation(fields: [customerAccountId], references: [id], onDelete: Cascade)
  assets              Asset[]
  workOrders          WorkOrder[]
  serviceReports      ServiceReport[]
  installateurAttachments InstallateurAttachment[]

  @@index([salonId, postcode])
  @@index([salonId, plaats])
  @@index([salonId, adresregel1])
  @@index([customerAccountId, postcode])
}

model Asset {
  id                    Int         @id @default(autoincrement())
  salonId               Int
  customerAccountId     Int
  serviceLocationId     Int
  type                  AssetType
  merk                  String?
  model                 String?
  serienummer           String?
  internNummer          String?
  status                AssetStatus @default(ACTIEF)
  plaatsingsDatum       DateTime?
  garantieTot           DateTime?
  laatsteOnderhoudDatum DateTime?
  omschrijving          String?
  notities              String?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  salon                 Salon       @relation(fields: [salonId], references: [id], onDelete: Cascade)
  customerAccount       CustomerAccount @relation(fields: [customerAccountId], references: [id], onDelete: Cascade)
  serviceLocation       ServiceLocation @relation(fields: [serviceLocationId], references: [id], onDelete: Cascade)
  workOrders            WorkOrder[]
  serviceReports        ServiceReport[]
  installateurAttachments InstallateurAttachment[]

  @@index([salonId, serienummer])
  @@index([serviceLocationId, type])
}

model WorkOrder {
  id                Int               @id @default(autoincrement())
  salonId           Int
  customerAccountId Int
  serviceLocationId Int
  assetId           Int?
  type              WorkOrderType
  status            WorkOrderStatus   @default(NIEUW)
  prioriteit        WorkOrderPriority @default(NORMAAL)
  titel             String
  melding           String
  interneNotities   String?
  klantNotities     String?
  requestedAt       DateTime          @default(now())
  geplandStart      DateTime?
  geplandEinde      DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  salon             Salon             @relation(fields: [salonId], references: [id], onDelete: Cascade)
  customerAccount   CustomerAccount   @relation(fields: [customerAccountId], references: [id], onDelete: Cascade)
  serviceLocation   ServiceLocation   @relation(fields: [serviceLocationId], references: [id], onDelete: Cascade)
  asset             Asset?            @relation(fields: [assetId], references: [id], onDelete: SetNull)
  assignments       WorkOrderAssignment[]
  serviceReport     ServiceReport?
  attachments       InstallateurAttachment[]

  @@index([salonId, status, geplandStart])
  @@index([customerAccountId, createdAt])
  @@index([serviceLocationId, requestedAt])
}

model WorkOrderAssignment {
  id                  Int                        @id @default(autoincrement())
  workOrderId         Int
  userId              Int
  rolOpOpdracht       WorkOrderAssignmentRole   @default(HOOFDMONTEUR)
  geplandStart        DateTime
  geplandEinde        DateTime
  daadwerkelijkeStart DateTime?
  daadwerkelijkeEinde DateTime?
  status              WorkOrderAssignmentStatus @default(INGEPLAND)
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt
  workOrder           WorkOrder                 @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  user                User                      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, geplandStart])
  @@index([workOrderId, geplandStart])
}

model ServiceReport {
  id                       Int             @id @default(autoincrement())
  salonId                  Int
  workOrderId              Int             @unique
  customerAccountId        Int
  serviceLocationId        Int
  assetId                  Int?
  ingevuldDoorUserId       Int?
  werkzaamhedenUitgevoerd  String
  bevindingen              String?
  advies                   String?
  vervolgActieNodig        Boolean         @default(false)
  vervolgActieOmschrijving String?
  afgerondOp               DateTime
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt
  salon                    Salon           @relation(fields: [salonId], references: [id], onDelete: Cascade)
  workOrder                WorkOrder       @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  customerAccount          CustomerAccount @relation(fields: [customerAccountId], references: [id], onDelete: Cascade)
  serviceLocation          ServiceLocation @relation(fields: [serviceLocationId], references: [id], onDelete: Cascade)
  asset                    Asset?          @relation(fields: [assetId], references: [id], onDelete: SetNull)
  ingevuldDoorUser         User?           @relation(fields: [ingevuldDoorUserId], references: [id], onDelete: SetNull)
  attachments              InstallateurAttachment[]

  @@index([salonId, afgerondOp])
  @@index([customerAccountId, afgerondOp])
}

model InstallateurAttachment {
  id               Int                       @id @default(autoincrement())
  salonId          Int
  customerAccountId Int?
  serviceLocationId Int?
  assetId          Int?
  workOrderId      Int
  serviceReportId  Int?
  uploadedByUserId Int?
  type             InstallateurAttachmentType
  url              String
  blobPath         String
  bestandNaam      String
  mimeType         String
  bestandGrootte   Int
  notitie          String?
  createdAt        DateTime                  @default(now())
  salon            Salon                     @relation(fields: [salonId], references: [id], onDelete: Cascade)
  customerAccount  CustomerAccount?          @relation(fields: [customerAccountId], references: [id], onDelete: Cascade)
  serviceLocation  ServiceLocation?          @relation(fields: [serviceLocationId], references: [id], onDelete: Cascade)
  asset            Asset?                    @relation(fields: [assetId], references: [id], onDelete: SetNull)
  workOrder        WorkOrder                 @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  serviceReport    ServiceReport?            @relation(fields: [serviceReportId], references: [id], onDelete: Cascade)
  uploadedByUser   User?                     @relation(fields: [uploadedByUserId], references: [id], onDelete: SetNull)

  @@index([salonId, createdAt])
  @@index([workOrderId, createdAt])
  @@index([serviceReportId, createdAt])
}
